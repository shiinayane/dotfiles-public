# Brewfile — 由 chezmoi 管理,新机器 `chezmoi apply` 时自动安装。
# 编辑本文件后再 apply 会自动重新 `brew bundle`(靠 run_onchange 脚本)。
# 注:不带 --cleanup,只增不删,手动卸载的包不会被这里重新装回。

# === CLI 工具 ===
brew "ast-grep"      # 结构化代码搜索/改写
brew "bat"           # cat 替代(高亮)
brew "btop"          # 资源监视器
brew "chezmoi"       # dotfiles 管理(自举)
brew "fastfetch"     # 系统信息
brew "fzf"           # 模糊查找
brew "mas"           # Mac App Store CLI(供下方 mas 条目使用)
brew "mise"          # 运行时版本管理(python/node/...)
brew "neovim"        # 编辑器
brew "tlrc"          # tldr 客户端
brew "uv"            # python 包/项目管理
brew "wget"
brew "zoxide"        # 智能 cd

# === 现代 CLI 替代 ===
brew "ripgrep"       # grep 替代(rg);nvim/fzf 搜索后端
brew "fd"            # find 替代;fzf/nvim find-files 后端(尊重 .gitignore)
brew "eza"           # ls 替代(图标 / git 状态)

# === Git ===
brew "gh"            # GitHub CLI
brew "lazygit"       # git TUI(LazyVim <leader>gg 直接调用)

# === Zsh 提示符与插件 ===
brew "powerlevel10k"     # 提示符(zsh-bench 实测最快,instant prompt)
brew "zsh-autosuggestions"
brew "zsh-completions"
brew "zsh-syntax-highlighting"

# === 字体 ===
cask "font-maple-mono-nf-cn"

# === GUI 应用 ===
