cask "visual-studio-code"
cask "claude"
cask "orbstack"              # Docker/Linux VM
cask "google-chrome"
cask "iina"                  # 播放器
cask "betterdisplay"
cask "loop"                  # 窗口管理
cask "appcleaner"
cask "tailscale-app"
cask "slack"
cask "wechat"
cask "microsoft-excel"

# === 排版 / 文档 ===
