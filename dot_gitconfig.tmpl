[user]
    name = Your Name
    email = you@example.com

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = simple
    autoSetupRemote = true

[core]
    editor = nvim
    autocrlf = input
    pager = less -FRX
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[fetch]
    prune = true

[rerere]
    enabled = true

[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    amend = commit --amend --no-edit
    lg = log --oneline --graph --decorate --all
    last = log -1 HEAD

[merge]
    tool = nvimdiff
    conflictStyle = zdiff3

[diff]
    tool = nvimdiff
    algorithm = histogram
    colorMoved = default

[rebase]
    autosquash = true
    autoStash = true

[branch]
    sort = -committerdate

[commit]
    verbose = true

[credential]
{{- if eq .chezmoi.os "darwin" }}
    helper = osxkeychain
{{- else }}
    helper = store
{{- end }}

# git-lfs filter(全平台:未装 git-lfs 时这些行不会被触发,无害;
# 装了的机器/远程 ML 机直接可用,且不再与本机产生 chezmoi drift)
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
